<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Slopworks.App.ViewModels"
             x:Class="Slopworks.App.Views.LogsView"
             x:DataType="vm:LogsViewModel">
  <Grid Margin="20" RowDefinitions="Auto,Auto,*">

    <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,10">
      <TextBlock Text="Logs" FontSize="26" FontWeight="Bold" />
      <TextBlock Text="{Binding StatusText}" Opacity="0.7" TextWrapping="Wrap"
                 MaxLines="2" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding StatusText}" />
    </StackPanel>

    <DockPanel Grid.Row="1" Margin="0,0,0,10">
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
        <Button Content="Refresh" Command="{Binding RefreshCommand}" />
        <Button Content="Copy" Click="Copy_Click" ToolTip.Tip="Copy the shown log text to the clipboard" />
        <Button Content="Open folder" Click="OpenFolder_Click" ToolTip.Tip="Open the logs folder in the file manager" />
      </StackPanel>
      <ComboBox ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedFile}"
                HorizontalAlignment="Stretch" MinWidth="320">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:LogFileItemViewModel">
            <TextBlock Text="{Binding Display}" FontFamily="Consolas,Menlo,monospace" FontSize="12" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </DockPanel>

    <Border Grid.Row="2" Background="#18000000" CornerRadius="8" Padding="10">
      <ScrollViewer>
        <SelectableTextBlock Text="{Binding Content}" FontFamily="Consolas,Menlo,monospace"
                             FontSize="12" TextWrapping="NoWrap" Opacity="0.9" />
      </ScrollViewer>
    </Border>

  </Grid>
</UserControl>
