<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Slopworks.App.ViewModels"
             x:Class="Slopworks.App.Views.TemplatesView"
             x:DataType="vm:TemplatesViewModel">
  <Grid Margin="20" RowDefinitions="Auto,Auto,*">

    <DockPanel Grid.Row="0" Margin="0,0,0,10">
      <Button DockPanel.Dock="Right" Content="Open templates folder" Click="OpenTemplatesFolder_Click"
              VerticalAlignment="Top"
              ToolTip.Tip="Open the folder holding the .jinja files — drop templates in here directly if you prefer" />
      <Button DockPanel.Dock="Right" Content="Refresh" Command="{Binding RefreshCommand}" VerticalAlignment="Top"
              Margin="0,0,8,0"
              ToolTip.Tip="Re-read the templates folder (e.g. after dropping .jinja files in directly)" />
      <StackPanel Spacing="6">
        <TextBlock Text="Chat templates" FontSize="26" FontWeight="Bold" />
        <TextBlock FontSize="13" Opacity="0.9" TextWrapping="Wrap"
                   Text="{Binding CurrentModel, StringFormat='Setting the chat template for model: {0}'}" />
        <TextBlock Text="{Binding StatusText}" Opacity="0.75" TextWrapping="Wrap"
                   MaxLines="2" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding StatusText}" />
      </StackPanel>
    </DockPanel>

    <Border Grid.Row="1" Background="#22E0A030" BorderBrush="#E0A030" BorderThickness="1" CornerRadius="6"
            Padding="10" Margin="0,0,0,12">
      <TextBlock TextWrapping="Wrap" FontSize="12"
                 Text="⚠ A chat template controls how prompts (system / tools / thinking) are built for the model. It replaces the model's built-in template server-wide (vLLM --chat-template). Review templates you paste or download from the internet before using them." />
    </Border>

    <Grid Grid.Row="2" ColumnDefinitions="300,16,*">

      <!-- Left: the template library + add / import -->
      <Grid Grid.Column="0" RowDefinitions="*,Auto,Auto,Auto,Auto,Auto">
        <ListBox Grid.Row="0" ItemsSource="{Binding Templates}" SelectedItem="{Binding SelectedTemplate}"
                 ToolTip.Tip="The selected template becomes the server's --chat-template. 'None' keeps the model's own." />

        <DockPanel Grid.Row="1" Margin="0,8,0,0">
          <Button DockPanel.Dock="Right" Content="New" Command="{Binding NewTemplateCommand}" Margin="8,0,0,0"
                  ToolTip.Tip="Create a new empty template (name optional — auto-named if blank)" />
          <TextBox Text="{Binding NewTemplateName}" PlaceholderText="new template name" />
        </DockPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
          <Button Content="Import file…" Click="ImportFile_Click"
                  ToolTip.Tip="Import a .jinja file from disk" />
          <Button Content="Duplicate" Command="{Binding DuplicateTemplateCommand}" />
          <Button Content="Delete" Command="{Binding DeleteTemplateCommand}"
                  ToolTip.Tip="Delete the selected template — press twice to confirm" />
        </StackPanel>

        <TextBlock Grid.Row="3" Text="Import from HuggingFace" FontSize="12" Opacity="0.7" Margin="0,12,0,2" />
        <TextBox Grid.Row="4" Text="{Binding ImportRepo}" PlaceholderText="repo id (org/name)" />
        <DockPanel Grid.Row="5" Margin="0,6,0,0">
          <Button DockPanel.Dock="Right" Content="Import" Command="{Binding ImportFromHfCommand}" Margin="8,0,0,0"
                  IsEnabled="{Binding !IsImporting}"
                  ToolTip.Tip="Download the given file from the repo's main branch into your templates folder" />
          <TextBox Text="{Binding ImportPath}" PlaceholderText="chat_template.jinja"
                   ToolTip.Tip="Path of the .jinja within the repo (default chat_template.jinja; use a subfolder path to pick a specific one)" />
        </DockPanel>
      </Grid>

      <!-- Right: edit the selected template -->
      <Grid Grid.Column="2" IsVisible="{Binding HasSelection}" RowDefinitions="Auto,Auto,*,Auto">
        <DockPanel Grid.Row="0">
          <Button DockPanel.Dock="Right" Content="Rename" Command="{Binding RenameTemplateCommand}" Margin="8,0,0,0" />
          <TextBox Text="{Binding RenameName}" ToolTip.Tip="Edit the template's name, then press Rename" />
        </DockPanel>

        <TextBlock Grid.Row="1" Text="Template (Jinja)" FontWeight="SemiBold" Opacity="0.85" Margin="0,10,0,4" />
        <TextBox Grid.Row="2" Text="{Binding TemplateContent}" AcceptsReturn="True" AcceptsTab="True"
                 FontFamily="Consolas,Menlo,monospace" FontSize="12" TextWrapping="NoWrap"
                 VerticalContentAlignment="Top"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                 PlaceholderText="{}{%- for message in messages -%} …" />

        <Button Grid.Row="3" Content="Save template" Command="{Binding SaveContentCommand}" Classes="accent"
                HorizontalAlignment="Right" Margin="0,8,0,0" />
      </Grid>

      <TextBlock Grid.Column="2" Text="Select a template on the left to edit it, or add / import one."
                 IsVisible="{Binding !HasSelection}" Opacity="0.5" VerticalAlignment="Top" TextWrapping="Wrap" />
    </Grid>
  </Grid>
</UserControl>
