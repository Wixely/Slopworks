<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Slopworks.App.ViewModels"
             x:Class="Slopworks.App.Views.SetupWizardView"
             x:DataType="vm:SetupWizardViewModel">
  <Grid Margin="20" RowDefinitions="Auto,Auto,*">

    <!-- Toolbar -->
    <DockPanel Grid.Row="0" Margin="0,0,0,10">
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10">
        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <TextBlock Text="Confirm each action" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
          <ToggleSwitch IsChecked="{Binding AutoMode}" OnContent="Auto" OffContent="Safe" />
        </StackPanel>
        <Button Content="Run setup" Command="{Binding StartCommand}" Classes="accent" />
        <Button Content="Cancel" Command="{Binding CancelCommand}" IsEnabled="{Binding IsRunning}" />
      </StackPanel>
      <StackPanel>
        <TextBlock Text="Setup" FontSize="26" FontWeight="Bold" />
        <TextBlock Text="{Binding StatusText}" Opacity="0.75" TextWrapping="Wrap" />
      </StackPanel>
    </DockPanel>

    <!-- Reboot banner -->
    <Border Grid.Row="1"
            IsVisible="{Binding RebootRequired}"
            Background="#334682B4" CornerRadius="8" Padding="12" Margin="0,0,0,10">
      <TextBlock TextWrapping="Wrap"
                 Text="Windows needs to restart to finish enabling WSL. Reboot, reopen Slopworks and run setup again — it resumes where it left off." />
    </Border>

    <Grid Grid.Row="2" ColumnDefinitions="360,12,*">

      <!-- Step list -->
      <ScrollViewer Grid.Column="0">
        <ItemsControl ItemsSource="{Binding Steps}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:StepStatusItemViewModel">
              <Border Margin="0,3" Padding="10,8" CornerRadius="6" Background="#22FFFFFF">
                <StackPanel Spacing="4">
                  <DockPanel>
                    <Border DockPanel.Dock="Right" Background="{Binding StateBrush}" CornerRadius="9" Padding="8,2">
                      <TextBlock Text="{Binding State}" FontSize="11" FontWeight="SemiBold" Foreground="White" />
                    </Border>
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                  </DockPanel>
                  <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" FontSize="12" Opacity="0.75" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Output + confirmation -->
      <Grid Grid.Column="2" RowDefinitions="*,Auto">
        <Border Grid.Row="0" Background="#18000000" CornerRadius="8" Padding="10">
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Output}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                  <TextBlock Text="{Binding}" FontFamily="Consolas,Menlo,monospace" FontSize="12"
                             TextWrapping="Wrap" Opacity="0.85" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <!-- Confirmation card -->
        <Border Grid.Row="1"
                IsVisible="{Binding CurrentApproval, Converter={x:Static ObjectConverters.IsNotNull}}"
                Background="#33DAA520" CornerRadius="8" Padding="14" Margin="0,10,0,0">
          <StackPanel Spacing="8" DataContext="{Binding CurrentApproval}" x:DataType="vm:PendingApprovalViewModel">
            <TextBlock FontWeight="SemiBold" Text="{Binding Description}" TextWrapping="Wrap" />
            <Border Background="#40000000" CornerRadius="4" Padding="8">
              <TextBlock Text="{Binding Detail}" FontFamily="Consolas,Menlo,monospace" FontSize="12" TextWrapping="Wrap" />
            </Border>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Approve" Command="{Binding ApproveCommand}" Classes="accent" />
              <Button Content="Approve all for this step" Command="{Binding ApproveAllForStepCommand}" />
              <Button Content="Deny" Command="{Binding DenyCommand}" />
              <Button Content="Abort run" Command="{Binding AbortCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
