<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Slopworks.App.ViewModels"
             x:Class="Slopworks.App.Views.SystemUsageView"
             x:DataType="vm:SystemUsageViewModel">
  <ScrollViewer>
    <StackPanel Margin="20" Spacing="18" MaxWidth="720" HorizontalAlignment="Left">

      <TextBlock Text="System" FontSize="26" FontWeight="Bold" />
      <TextBlock Text="Whole-machine usage (includes WSL and the vLLM container), sampled every second."
                 Opacity="0.7" TextWrapping="Wrap" />

      <!-- CPU (left) and RAM (right) share a row. CPU is processing → darker blue;
           RAM is memory → lighter blue. -->
      <Grid ColumnDefinitions="*,20,*">
        <StackPanel Grid.Column="0" Spacing="6">
          <TextBlock Text="{Binding CpuLabel}" FontWeight="SemiBold" />
          <ProgressBar Minimum="0" Maximum="100" Value="{Binding CpuPercent}" Height="26" CornerRadius="6"
                       Foreground="#1D4ED8" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="6">
          <TextBlock Text="{Binding RamLabel}" FontWeight="SemiBold" />
          <ProgressBar Minimum="0" Maximum="100" Value="{Binding RamPercent}" Height="26" CornerRadius="6"
                       Foreground="#60A5FA" />
        </StackPanel>
      </Grid>

      <!-- GPU is green; processing → darker green, VRAM → lighter green. -->
      <ItemsControl ItemsSource="{Binding Gpus}" IsVisible="{Binding HasGpus}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:GpuUsageItemViewModel">
            <StackPanel Spacing="6" Margin="0,10,0,0">
              <TextBlock Text="{Binding Header}" FontWeight="SemiBold" FontSize="15" />
              <!-- Processing (left) and VRAM (right) share a row, like CPU/RAM above. -->
              <Grid ColumnDefinitions="*,20,*">
                <StackPanel Grid.Column="0" Spacing="6">
                  <TextBlock Text="{Binding UtilizationLabel}" FontSize="13" Opacity="0.85" />
                  <ProgressBar Minimum="0" Maximum="100" Value="{Binding UtilizationPercent}" Height="26" CornerRadius="6"
                               Foreground="#15803D" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="6">
                  <TextBlock Text="{Binding VramLabel}" FontSize="13" Opacity="0.85" />
                  <ProgressBar Minimum="0" Maximum="100" Value="{Binding VramPercent}" Height="26" CornerRadius="6"
                               Foreground="#4ADE80" />
                </StackPanel>
              </Grid>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <TextBlock Text="No NVIDIA GPU detected — GPU bars appear when a card and driver are present."
                 IsVisible="{Binding !HasGpus}" Opacity="0.55" FontSize="12" />

    </StackPanel>
  </ScrollViewer>
</UserControl>
