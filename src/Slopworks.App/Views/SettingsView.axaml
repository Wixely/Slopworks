<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Slopworks.App.ViewModels"
             x:Class="Slopworks.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <Grid Margin="20" RowDefinitions="Auto,*">

    <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,12">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <Button Content="Save" Command="{Binding SaveCommand}" Classes="accent" />
          <Button Content="Discard changes" Command="{Binding DiscardChangesCommand}" />
        </StackPanel>
        <TextBlock Text="Settings" FontSize="26" FontWeight="Bold" />
      </DockPanel>
      <TextBlock Text="{Binding StatusText}" Opacity="0.75" TextWrapping="Wrap"
                 MaxLines="2" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding StatusText}" />
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="*,16,300">
      <ScrollViewer Grid.Column="0">
        <StackPanel Spacing="18">

        <Border Background="#22E0A030" BorderBrush="#E0A030" BorderThickness="1" CornerRadius="6" Padding="10">
          <TextBlock TextWrapping="Wrap" FontSize="12"
                     Text="⚠ These settings are assembled into a shell command that runs on your machine. If you import a profile or paste extra arguments / model ids from the internet, vet them first — crafted values can execute arbitrary commands." />
        </Border>

        <StackPanel Spacing="8">
          <TextBlock Text="vLLM server" FontWeight="SemiBold" FontSize="16" />
          <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" >
            <TextBlock Grid.Row="0" Text="Port" VerticalAlignment="Center" />
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Port}" Margin="0,2" />
            <TextBlock Grid.Row="1" Text="Model (HuggingFace id)" VerticalAlignment="Center" />
            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
              <TextBox Text="{Binding Model}" Margin="0,2"
                       ToolTip.Tip="A HuggingFace repo id like org/model or org/model-AWQ. Not an Ollama 'hf.co/…:tag' string, and not a GGUF-only repo — vLLM needs safetensors + config.json." />
              <TextBlock Text="{Binding ModelAdvisory}" IsVisible="{Binding HasModelAdvisory}"
                         Foreground="#E0A030" FontSize="12" TextWrapping="Wrap" />
            </StackPanel>
            <TextBlock Grid.Row="2" Text="GPU memory utilization" VerticalAlignment="Center"
                       ToolTip.Tip="Fraction of each GPU vLLM reserves. Lower it (e.g. 0.8) if the GPU also drives your display." />
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding GpuMemoryUtilization}" Margin="0,2" />
            <TextBlock Grid.Row="3" Text="Log level" VerticalAlignment="Center"
                       ToolTip.Tip="VLLM_LOGGING_LEVEL. DEBUG is the most verbose — use it to see request detail when diagnosing 400s. Restart the server after changing." />
            <ComboBox Grid.Row="3" Grid.Column="1" MinWidth="160" Margin="0,2"
                      ItemsSource="{Binding LogLevelOptions}" SelectedItem="{Binding VllmLogLevel}" />
            <TextBlock Grid.Row="4" Text="Extra vLLM arguments" VerticalAlignment="Top" Margin="0,6,0,0"
                       ToolTip.Tip="Appended after --model. One argument per line, e.g. --max-model-len 8192" />
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ExtraVllmArgs}" AcceptsReturn="True"
                     MinHeight="56" FontFamily="Consolas,Menlo,monospace" FontSize="12" Margin="0,2"
                     PlaceholderText="--max-model-len 8192&#x0a;--dtype float16" />
            <TextBlock Grid.Row="5" Text="Extra container arguments" VerticalAlignment="Top" Margin="0,6,0,0"
                       ToolTip.Tip="Podman flags inserted before the image. One per line, e.g. --memory 24g" />
            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding ExtraContainerArgs}" AcceptsReturn="True"
                     MinHeight="56" FontFamily="Consolas,Menlo,monospace" FontSize="12" Margin="0,2"
                     PlaceholderText="--memory 24g" />
          </Grid>

          <Grid ColumnDefinitions="220,*">
            <TextBlock Text="Context size (max tokens)" VerticalAlignment="Center"
                       ToolTip.Tip="vLLM --max-model-len. Blank = the model's full context, which can be huge (e.g. 262144) and needs a large KV cache. Lower it (e.g. 8192 or 16384) to cut VRAM use and fit a model. Restart the server to apply." />
            <TextBox Grid.Column="1" Text="{Binding MaxModelLen}" Margin="0,2" PlaceholderText="model default (leave blank)" />
          </Grid>

          <Grid ColumnDefinitions="220,*">
            <TextBlock Text="Quantization" VerticalAlignment="Center"
                       ToolTip.Tip="--quantization. Leave on auto: vLLM reads the method from the checkpoint. awq, gptq, nvfp4, modelopt_fp4, compressed-tensors REQUIRE a repo that is already quantized that way (setting them on a full model fails: 'Cannot find the config file for …') — for those, put the pre-quantized repo in Model and keep this on auto. bitsandbytes is the only on-the-fly option (quantizes a full model at load time, single-GPU only). fp8 = Hopper/Blackwell (5090)." />
            <ComboBox Grid.Column="1" MinWidth="220" Margin="0,2"
                      ItemsSource="{Binding QuantizationOptions}" SelectedItem="{Binding Quantization}" />
          </Grid>

          <Grid ColumnDefinitions="220,*">
            <TextBlock Text="KV cache quantization" VerticalAlignment="Center"
                       ToolTip.Tip="vLLM --kv-cache-dtype. auto = model dtype. fp8 (e4m3) roughly halves the KV-cache VRAM, so you can fit longer context or a bigger model; fp8_e5m2 trades precision for range. Pair with Context size for tight VRAM. Restart the server to apply." />
            <ComboBox Grid.Column="1" MinWidth="220" Margin="0,2"
                      ItemsSource="{Binding KvCacheOptions}" SelectedItem="{Binding KvCacheDtype}" />
          </Grid>

          <Grid ColumnDefinitions="220,*">
            <TextBlock Text="Compute dtype" VerticalAlignment="Center"
                       ToolTip.Tip="vLLM --dtype. auto matches the checkpoint's own precision (recommended). bfloat16/float16 force half precision; float32 is rarely needed and doubles VRAM. Restart the server to apply." />
            <ComboBox Grid.Column="1" MinWidth="160" Margin="0,2" HorizontalAlignment="Left"
                      ItemsSource="{Binding DtypeOptions}" SelectedItem="{Binding Dtype}" />
          </Grid>

          <Grid ColumnDefinitions="220,*">
            <TextBlock Text="Max concurrent sequences" VerticalAlignment="Center"
                       ToolTip.Tip="vLLM --max-num-seqs. Blank = vLLM default (256). Lower it (e.g. 1–2) so one long-context request can claim more KV cache — it's a cap, not a reservation, so short requests are unaffected. Restart the server to apply." />
            <TextBox Grid.Column="1" Text="{Binding MaxNumSeqs}" Margin="0,2" PlaceholderText="vLLM default (leave blank)" />
          </Grid>

          <CheckBox IsChecked="{Binding EnforceEager}"
                    Content="Run fully eager (--enforce-eager)"
                    ToolTip.Tip="Turns off BOTH torch.compile and CUDA graphs — the most compatible but slowest. Frees the CUDA-graph VRAM (a documented WSL2 long-context requirement). To keep torch.compile and drop only CUDA graphs, use the option below instead." />

          <CheckBox IsChecked="{Binding CudaGraphModeNone}"
                    Content="Disable CUDA graphs only, keep torch.compile (-cc.cudagraph_mode=NONE)"
                    ToolTip.Tip="Disables only CUDA-graph capture while torch.compile and its kernel optimizations stay on — a lighter alternative to --enforce-eager. Frees the same CUDA-graph VRAM and avoids graph-capture issues, but stays faster than full eager." />

          <CheckBox IsChecked="{Binding TrustRemoteCode}"
                    Content="Trust remote code (--trust-remote-code)"
                    ToolTip.Tip="Lets the model repo run its own modeling code — some architectures need it to load at all. Only enable for repos you trust: it executes code straight from the repo." />

          <CheckBox IsChecked="{Binding EnableToolCalling}"
                    Content="Enable tool / function calling (--enable-auto-tool-choice)"
                    ToolTip.Tip="Agents that send tools with tool_choice=auto need this, or vLLM returns 400. On by default." />
          <Grid ColumnDefinitions="220,*" IsVisible="{Binding EnableToolCalling}">
            <TextBlock Text="Tool call parser" VerticalAlignment="Center"
                       ToolTip.Tip="--tool-call-parser, must match the model's tool format. Type any value, or pick a preset. Common: hermes (Qwen/Hermes), llama3_json, mistral, pythonic, qwen3_coder." />
            <DockPanel Grid.Column="1" Margin="0,2">
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4" Margin="6,0,0,0">
                <Button Content="hermes" Command="{Binding SetToolParserCommand}" CommandParameter="hermes"
                        Padding="8,3" FontSize="12" ToolTip.Tip="Qwen / Hermes (most Qwen2.5 / Qwen3 models)" />
                <Button Content="llama3_json" Command="{Binding SetToolParserCommand}" CommandParameter="llama3_json"
                        Padding="8,3" FontSize="12" ToolTip.Tip="Llama 3.1 / 3.2" />
                <Button Content="mistral" Command="{Binding SetToolParserCommand}" CommandParameter="mistral"
                        Padding="8,3" FontSize="12" ToolTip.Tip="Mistral / Mixtral" />
                <Button Content="pythonic" Command="{Binding SetToolParserCommand}" CommandParameter="pythonic"
                        Padding="8,3" FontSize="12" ToolTip.Tip="Llama 4 and other pythonic-format models" />
                <Button Content="qwen3_coder" Command="{Binding SetToolParserCommand}" CommandParameter="qwen3_coder"
                        Padding="8,3" FontSize="12" ToolTip.Tip="Qwen3 Coder" />
              </StackPanel>
              <TextBox Text="{Binding ToolCallParser}" PlaceholderText="hermes" VerticalAlignment="Center" />
            </DockPanel>
          </Grid>

          <CheckBox IsChecked="{Binding ShowAdvancedServer}" Content="Show advanced vLLM options" Margin="0,4,0,0" />
          <StackPanel Spacing="8" IsVisible="{Binding ShowAdvancedServer}">
            <Grid ColumnDefinitions="220,*">
              <TextBlock Text="Max batched tokens" VerticalAlignment="Center"
                         ToolTip.Tip="vLLM --max-num-batched-tokens. Blank = vLLM default. Chunked-prefill token budget per step: lower it to soften prefill/decode starvation when long prompts and active generations share the GPU, raise it to speed bulk prefill." />
              <TextBox Grid.Column="1" Text="{Binding MaxNumBatchedTokens}" Margin="0,2" PlaceholderText="vLLM default (leave blank)" />
            </Grid>
            <Grid ColumnDefinitions="220,*">
              <TextBlock Text="Prefix caching" VerticalAlignment="Center"
                         ToolTip.Tip="vLLM --enable-prefix-caching / --no-enable-prefix-caching. 'vLLM default' leaves it as vLLM ships it (on in current versions). Caching shared prompt prefixes is a big win for agents that reuse a system prompt; set Off only to isolate a caching issue." />
              <ComboBox Grid.Column="1" MinWidth="160" Margin="0,2" HorizontalAlignment="Left"
                        ItemsSource="{Binding PrefixCachingOptions}" SelectedIndex="{Binding PrefixCachingIndex}" />
            </Grid>
            <Grid ColumnDefinitions="220,*">
              <TextBlock Text="Served model name" VerticalAlignment="Center"
                         ToolTip.Tip="vLLM --served-model-name. The id the API advertises at /v1/models instead of the full repo path — point an agent at a short, stable name (e.g. 'local'). Blank = serve under the model id." />
              <TextBox Grid.Column="1" Text="{Binding ServedModelName}" Margin="0,2" PlaceholderText="(model id)" />
            </Grid>
          </StackPanel>
        </StackPanel>

        <StackPanel Spacing="8">
          <TextBlock Text="GPUs" FontWeight="SemiBold" FontSize="16" />
          <TextBlock Text="{Binding GpuHint}" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />

          <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto" IsVisible="{Binding HasGpus}">
            <TextBlock Grid.Row="0" Text="Split across GPUs" VerticalAlignment="Center"
                       ToolTip.Tip="Tensor parallel size — split the model across this many GPUs. Must divide the model's attention-head count; use matching cards." />
            <ComboBox Grid.Row="0" Grid.Column="1" MinWidth="120" Margin="0,2"
                      ItemsSource="{Binding TensorParallelOptions}" SelectedItem="{Binding SelectedTensorParallel}" />
            <TextBlock Grid.Row="1" Text="CUDA device order" VerticalAlignment="Center" Margin="0,4,0,0"
                       ToolTip.Tip="PCI bus order makes CUDA indices match nvidia-smi and silences the mixed-GPU ordering warning." />
            <ComboBox Grid.Row="1" Grid.Column="1" MinWidth="320" Margin="0,4,0,0"
                      ItemsSource="{Binding DeviceOrderOptions}" SelectedIndex="{Binding SelectedDeviceOrderIndex}" />
          </Grid>

          <StackPanel IsVisible="{Binding HasGpus}" Spacing="2" Margin="0,4,0,0">
            <CheckBox IsChecked="{Binding DisableGpuP2P}"
                      Content="Disable GPU peer-to-peer / NVLink (NCCL_P2P_DISABLE) for multi-GPU"
                      ToolTip.Tip="WSL doesn't support PCIe peer-to-peer, but NVLink works. Leave unchecked to use NVLink; check it if you have no NVLink or hit 'invalid resource handle'." />
            <TextBlock Text="{Binding NvLinkHint}" FontSize="12" Opacity="0.65" TextWrapping="Wrap" Margin="26,0,0,0" />
          </StackPanel>

          <StackPanel IsVisible="{Binding HasGpus}" Spacing="2">
            <TextBlock Text="Use these GPUs" FontSize="13" Opacity="0.85" Margin="0,4,0,0" />
            <ItemsControl ItemsSource="{Binding Gpus}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:GpuCheckItemViewModel">
                  <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding Label}"
                            FontFamily="Consolas,Menlo,monospace" FontSize="12" Margin="0,1" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </StackPanel>

        <StackPanel Spacing="8">
          <TextBlock Text="Platform" FontWeight="SemiBold" FontSize="16" />
          <TextBlock Text="Container images + distro source come from a platform. Edit platforms on the Platform tab; here you just pick which one this profile uses."
                     FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
          <Grid ColumnDefinitions="220,*">
            <TextBlock Text="Platform" VerticalAlignment="Center"
                       ToolTip.Tip="(Default) uses whichever platform is marked default on the Platform tab." />
            <ComboBox Grid.Column="1" MinWidth="240" Margin="0,2" HorizontalAlignment="Left"
                      ItemsSource="{Binding PlatformOptions}" SelectedItem="{Binding SelectedPlatformOption}" />
          </Grid>
        </StackPanel>

        <StackPanel Spacing="8">
          <TextBlock Text="Network &amp; behavior" FontWeight="SemiBold" FontSize="16" />
          <Grid ColumnDefinitions="220,*" RowDefinitions="Auto">
            <TextBlock Text="Proxy (http://host:port)" VerticalAlignment="Center"
                       ToolTip.Tip="Propagated to downloads, apt inside the distro, and the container's model downloads" />
            <TextBox Grid.Column="1" Text="{Binding Proxy}" Margin="0,2" />
          </Grid>
          <CheckBox IsChecked="{Binding AllowSystemProxy}" Content="Use the system proxy when none is set above" />
          <CheckBox IsChecked="{Binding AutoApproveInsideRoot}"
                    Content="In safe mode, skip prompts for file writes confined to the Slopworks folder" />
        </StackPanel>

        <StackPanel Spacing="6">
          <TextBlock Text="{Binding PreviewLabel}" FontWeight="SemiBold" FontSize="13" />
          <Border Background="#18000000" CornerRadius="8" Padding="10">
            <SelectableTextBlock Text="{Binding CommandPreview}" FontFamily="Consolas,Menlo,monospace"
                                 FontSize="12" TextWrapping="Wrap" Opacity="0.9" />
          </Border>
          <TextBlock Text="The token is masked here; the real value is injected via an environment variable at start."
                     FontSize="11" Opacity="0.55" />
        </StackPanel>

        </StackPanel>
      </ScrollViewer>

      <Border Grid.Column="2" Background="#14000000" CornerRadius="8" Padding="12">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Text="Profiles" FontWeight="SemiBold" FontSize="16" />
          <TextBlock Grid.Row="1" Text="Named settings files. Click one to use it, then edit its name below. The settings on the left edit the selected profile."
                     FontSize="12" Opacity="0.65" TextWrapping="Wrap" Margin="0,2,0,8" />
          <ListBox Grid.Row="2" MinHeight="140" ItemsSource="{Binding Profiles}"
                   SelectedItem="{Binding SelectedProfile}" />
          <DockPanel Grid.Row="3" Margin="0,8,0,0">
            <Button DockPanel.Dock="Right" Content="Rename" Command="{Binding RenameProfileCommand}" Margin="8,0,0,0"
                    ToolTip.Tip="Rename the selected profile" />
            <TextBox Text="{Binding ProfileNameEdit}" ToolTip.Tip="Edit the selected profile's name, then press Rename" />
          </DockPanel>
          <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
            <Button Content="New" Command="{Binding CreateProfileCommand}"
                    ToolTip.Tip="Create a new profile from default settings (auto-named — rename it above)" />
            <Button Content="Duplicate" Command="{Binding DuplicateProfileCommand}"
                    ToolTip.Tip="Copy the active profile (auto-named — rename it above)" />
          </StackPanel>
          <Button Grid.Row="5" Content="Delete" Command="{Binding DeleteProfileCommand}"
                  HorizontalAlignment="Stretch" Margin="0,6,0,0"
                  ToolTip.Tip="Delete the active profile — press twice to confirm" />
          <Button Grid.Row="6" Content="Open profiles folder" Click="OpenProfilesFolder_Click"
                  HorizontalAlignment="Stretch" Margin="0,6,0,0"
                  ToolTip.Tip="Open the folder containing the profile .json files" />
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
