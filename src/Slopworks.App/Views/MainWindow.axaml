<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Slopworks.App.ViewModels"
        xmlns:views="using:Slopworks.App.Views"
        x:Class="Slopworks.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Slopworks"
        Width="1080" Height="720"
        WindowStartupLocation="CenterScreen">
  <TabControl Margin="4">
    <TabItem Header="Dashboard">
      <views:DashboardView DataContext="{Binding Dashboard}" />
    </TabItem>
    <TabItem Header="Setup">
      <views:SetupWizardView DataContext="{Binding Wizard}" />
    </TabItem>
    <TabItem Header="Server">
      <views:ServerView DataContext="{Binding Server}" />
    </TabItem>
    <TabItem Header="Maintenance">
      <views:MaintenanceView DataContext="{Binding Maintenance}" />
    </TabItem>
  </TabControl>
</Window>
