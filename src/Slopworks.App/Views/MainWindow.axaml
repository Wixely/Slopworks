<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Slopworks.App.ViewModels"
        xmlns:views="using:Slopworks.App.Views"
        x:Class="Slopworks.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Slopworks"
        Icon="/Assets/icon.png"
        Width="1080" Height="720"
        WindowStartupLocation="CenterScreen">
  <TabControl Margin="4" SelectedIndex="{Binding SelectedTabIndex}">
    <TabItem Header="Dashboard">
      <views:DashboardView DataContext="{Binding Dashboard}" />
    </TabItem>
    <TabItem Header="Setup">
      <views:SetupWizardView DataContext="{Binding Wizard}" />
    </TabItem>
    <TabItem Header="Server">
      <views:ServerView DataContext="{Binding Server}" />
    </TabItem>
    <TabItem Header="System">
      <views:SystemUsageView DataContext="{Binding SystemUsage}" />
    </TabItem>
    <TabItem Header="Models">
      <views:ModelsView DataContext="{Binding Models}" />
    </TabItem>
    <TabItem Header="Settings">
      <views:SettingsView DataContext="{Binding Settings}" />
    </TabItem>
    <TabItem Header="Platform">
      <views:PlatformsView DataContext="{Binding Platforms}" />
    </TabItem>
    <TabItem Header="Maintenance">
      <views:MaintenanceView DataContext="{Binding Maintenance}" />
    </TabItem>
    <TabItem Header="Logs">
      <views:LogsView DataContext="{Binding Logs}" />
    </TabItem>
  </TabControl>
</Window>
