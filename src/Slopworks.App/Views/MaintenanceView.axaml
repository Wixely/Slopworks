<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Slopworks.App.ViewModels"
             x:Class="Slopworks.App.Views.MaintenanceView"
             x:DataType="vm:MaintenanceViewModel">
  <Grid Margin="20" RowDefinitions="Auto,Auto,*,Auto">

    <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,12">
      <DockPanel>
        <Button DockPanel.Dock="Right" Content="Refresh" Command="{Binding RefreshCommand}"
                IsEnabled="{Binding !IsBusy}" />
        <TextBlock Text="Maintenance &amp; Uninstall" FontSize="26" FontWeight="Bold" />
      </DockPanel>
      <TextBlock Text="{Binding StatusText}" Opacity="0.75" TextWrapping="Wrap"
                 MaxLines="3" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding StatusText}" />
    </StackPanel>

    <Border Grid.Row="1" Background="#33B22222" CornerRadius="8" Padding="12" Margin="0,0,0,12">
      <DockPanel>
        <Button DockPanel.Dock="Right" Content="Remove everything"
                Command="{Binding RemoveEverythingCommand}" IsEnabled="{Binding !IsBusy}"
                Margin="12,0,0,0" VerticalAlignment="Center" />
        <StackPanel Spacing="4">
          <TextBlock Text="Undo all changes Slopworks has made to this machine" FontWeight="SemiBold" />
          <CheckBox IsChecked="{Binding IncludeWslInFullRemoval}"
                    IsVisible="{Binding ShowWslOption}"
                    Content="Also remove WSL itself (system-wide — read the warning on the WSL item below first)" />
        </StackPanel>
      </DockPanel>
    </Border>

    <ScrollViewer Grid.Row="2">
      <ItemsControl ItemsSource="{Binding Items}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:CleanupItemViewModel">
            <Border Margin="0,4" Padding="14,10" CornerRadius="8" Background="#22FFFFFF">
              <DockPanel>
                <Button DockPanel.Dock="Right" Content="Remove"
                        Command="{Binding RemoveCommand}" IsEnabled="{Binding Present}"
                        Margin="12,0,0,0" VerticalAlignment="Center" />
                <StackPanel Spacing="3">
                  <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding Description}" FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding Detail}" FontSize="13" Opacity="0.85" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding Warning}" IsVisible="{Binding HasWarning}"
                             Foreground="Orange" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
              </DockPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <Expander Grid.Row="3" Header="What remains after a full uninstall" Margin="0,10,0,0">
      <TextBlock Text="{Binding WhatRemains}" TextWrapping="Wrap" FontSize="12" Opacity="0.8" Margin="4" />
    </Expander>

  </Grid>
</UserControl>
