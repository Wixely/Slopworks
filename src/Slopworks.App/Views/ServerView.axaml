<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Slopworks.App.ViewModels"
             x:Class="Slopworks.App.Views.ServerView"
             x:DataType="vm:ServerViewModel">
  <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,*">

    <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,14">
      <TextBlock Text="Server" FontSize="26" FontWeight="Bold" />
      <TextBlock Text="{Binding StatusText}" Opacity="0.75" TextWrapping="Wrap" />
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="0,0,0,10">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Model (HuggingFace id)" VerticalAlignment="Center" Margin="0,0,10,6" />
      <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Model}" PlaceholderText="Qwen/Qwen2.5-0.5B-Instruct" Margin="0,0,0,6" />
      <TextBlock Grid.Row="1" Grid.Column="0" Text="HuggingFace token" VerticalAlignment="Center" Margin="0,0,10,0" />
      <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding HfToken}" PasswordChar="•" PlaceholderText="only needed for gated models" />
    </Grid>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
      <Button Content="Start" Command="{Binding StartCommand}" Classes="accent" IsEnabled="{Binding !IsBusy}" />
      <Button Content="Stop" Command="{Binding StopCommand}" IsEnabled="{Binding !IsBusy}" />
      <Button Content="Refresh" Command="{Binding RefreshCommand}" IsEnabled="{Binding !IsBusy}" />
      <Button Content="Tail logs" Command="{Binding TailLogsCommand}" IsEnabled="{Binding !IsBusy}" />
      <Button Content="Fix port forwarding" Command="{Binding RepairForwardingCommand}" IsEnabled="{Binding !IsBusy}"
              ToolTip.Tip="Restarts WSL — use when localhost stops responding after the machine slept" />
    </StackPanel>

    <Border Grid.Row="3" Background="#18000000" CornerRadius="8" Padding="10">
      <ScrollViewer>
        <SelectableTextBlock Text="{Binding Logs}" FontFamily="Consolas,Menlo,monospace" FontSize="12" Opacity="0.85" />
      </ScrollViewer>
    </Border>

  </Grid>
</UserControl>
